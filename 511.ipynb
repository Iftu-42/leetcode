import pandas as pd

def game_analysis(activity: pd.DataFrame) -> pd.DataFrame:
#first lets break it down...
    # 1. Group by player_id
    # 2. Select the event_date column
    # 3. Find the minimum date for each group
    # 4. Rename the resulting column to 'first_login'
    # 5. Reset the index to turn player_id back into a column
    result = activity.groupby('player_id')['event_date'].min().reset_index()
    result.columns = ['player_id', 'first_login']
    
    return result
